    D1 -->|LimasSegiEmpatSembarang extends SegiEmpat| R2[Override: super.hitungLuas, volume 1/3 x luas x t, LP limas]
    D1 -->|PrismaSegiEmpatSembarang extends SegiEmpat| R3[Override: super.hitungLuas, volume luas x tinggi, LP prisma]
    R1 --> OUT[/Return double ke GeoProcessor/]
    R2 --> OUT
    R3 --> OUT
    OUT --> END([Lanjut displayResult])
